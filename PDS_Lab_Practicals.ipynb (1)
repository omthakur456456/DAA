.datasets import load_iris\n","\n","# Load a realistic dataset (Iris dataset)\n","iris = load_iris()\n","X = iris.data\n","y = iris.target # True labels (for reference, not used in clustering itself)\n","\n","# Scaling\n","scaler = StandardScaler()\n","X_scaled = scaler.fit_transform(X)\n","\n","# K-Means (Iris has 3 classes)\n","kmeans = KMeans(n_clusters=3, random_state=0, n_init='auto')\n","kmeans_labels = kmeans.fit_predict(X_scaled)\n","\n","# Hierarchical (Iris has 3 classes)\n","hc = AgglomerativeClustering(n_clusters=3)\n","hc_labels = hc.fit_predict(X_scaled)\n","\n","# DBSCAN (parameters might need tuning for optimal results on Iris)\n","db = DBSCAN(eps=0.5, min_samples=5) # Adjusted eps and min_samples for Iris data\n","db_labels = db.fit_predict(X_scaled)\n","\n","# Output\n","print(\"K-Means:\", kmeans_labels)\n","print(\"Hierarchical:\", hc_labels)\n","print(\"DBSCAN:\", db_labels)\n","\n","# Visualization (using the first two features of Iris and K-Means labels)\n","plt.figure(figsize=(10, 6))\n","plt.scatter(X[:, 0], X[:, 1], c=kmeans_labels, cmap='viridis', s=50)\n","plt.xlabel(iris.feature_names[0])\n","plt.ylabel(iris.feature_names[1])\n","plt.title(\"K-Means Clustering on Iris Dataset (Features 0 and 1)\")\n","plt.colorbar(label='Cluster Label')\n","plt.show()\n","\n","plt.figure(figsize=(10, 6))\n","plt.scatter(X[:, 0], X[:, 1], c=y, cmap='viridis', s=50)\n","plt.xlabel(iris.feature_names[0])\n","plt.ylabel(iris.feature_names[1])\n","plt.title(\"True Classes of Iris Dataset (Features 0 and 1)\")\n","plt.colorbar(label='True Class Label')\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"Ayoiqt-RzmXw","executionInfo":{"status":"ok","timestamp":1776485983633,"user_tz":-330,"elapsed":1685,"user":{"displayName":"omsingh Thakur","userId":"11353487019872965538"}},"outputId":"20009373-e9c3-47dc-94b5-685511eb8759"},"id":"Ayoiqt-RzmXw","execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","te