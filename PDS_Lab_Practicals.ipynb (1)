=10, label='Train data')\n","\n","plt.scatter(reg.predict(X_test),\n","            reg.predict(X_test) - y_test,\n","            color=\"blue\", s=10, label='Test data')\n","\n","plt.hlines(y=0, xmin=min(reg.predict(X_train).min(), reg.predict(X_test).min()),\n","           xmax=max(reg.predict(X_train).max(), reg.predict(X_test).max()), linewidth=2)\n","plt.legend(loc='upper right')\n","plt.title(\"Residual Errors\")\n","plt.xlabel(\"Predicted Values\")\n","plt.ylabel(\"Residuals\")\n","plt.show()\n","\n","print(\"\\nConclusion: Thus we have studied multiple regression modelling.\")"]},{"cell_type":"markdown","id":"practical-8-title","metadata":{"id":"practical-8-title"},"source":["# Practical No 8\n","**Aim:** To Implement classification models on data sets\n","\n","**Software Used:** Google Colab / Jupyter Notebook"]},{"cell_type":"code","execution_count":null,"id":"practical-8-code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":715},"id":"practical-8-code","executionInfo":{"status":"ok","timestamp":1776484899087,"user_tz":-330,"elapsed":466,"user":{"displayName":"omsingh Thakur","userId":"11353487019872965538"}},"outputId":"a3d136ab-145e-41b9-a138-b85a31077716"},"outputs":[{"output_type":"stream","name":"stdout","text":["Dataset Shape: (569, 30)\n","Class Distribution:\n","label\n","1    357\n","0    212\n","Name: count, dtype: int64\n","\n","Training samples: 398, Testing samples: 171\n","\n","Accuracy: 0.9707602339181286\n","\n","Confusion Matrix:\n","[[ 60   3]\n"," [  2 106]]\n","\n","Classification Report:\n","              precision    recall  f1-score   support\n","\n","           0       0.97      0.95      0.96        63\n","           1       0.97      0.98      0.98       108\n","\n","    accuracy                           0.97       171\n","   macro avg       0.97      0.97      0.97       171\n","weighted avg       0.97      0.97      0.97       171\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x